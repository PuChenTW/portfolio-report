# ── Telegram ────────────────────────────────────────────────────────────────
# Required: obtain from @BotFather
TELEGRAM_BOT_TOKEN=

# Required: your personal chat ID (send a message to @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ── API keys ─────────────────────────────────────────────────────────────────
# Required for AI research and chat (Google Gemini)
GOOGLE_API_KEY=

# Required for web/news search via Tavily (https://tavily.com)
TAVILY_API_KEY=

# ── File paths ───────────────────────────────────────────────────────────────
# Optional: paths below match the defaults — only set if you move the files
PORTFOLIO_CSV_PATH=./portfolio.csv
WATCHLIST_CSV_PATH=./watchlist.csv
PRICE_ALERTS_PATH=./price-alerts.yml
RESEARCHER_MEMORY_PATH=./memory

# ── Models ───────────────────────────────────────────────────────────────────
# Optional: override the model used by the free-chat agent
# CHAT_MODEL=google-gla:gemini-3-flash-preview
